generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id   String @id @default(cuid())
  role String @default("customer") // customer | admin | cms_admin

  name  String
  email String? @unique
  phone String? @unique

  passwordHash String

  emailVerified       Boolean   @default(false)
  emailOtpHash        String?
  emailOtpExpiresAt   DateTime?
  emailOtpAttempts    Int       @default(0)
  emailOtpLastSentAt  DateTime?

  cart Cart?

  orders           Order[]
  checkoutSessions CheckoutSession[]
  returnRequests   ReturnRequest[]
  passwordResets   PasswordReset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  logoUrl String?
  status  String  @default("active") // active | inactive

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id     String @id @default(cuid())
  name   String
  slug   String @unique
  status String @default("active") // active | inactive

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id   String @id @default(cuid())
  name String
  slug String @unique

  description String?

  basePrice Int
  baseStock Int

  discountType    String? // percent | fixed
  discountValue   Int?
  discountStartAt DateTime?
  discountEndAt   DateTime?

  prescriptionRequired Boolean @default(false)

  status   String  @default("active") // active | draft | out_of_stock
  featured Boolean @default(false)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images   ProductImage[]
  variants ProductVariant[]

  // added for CartItem relation (opposite side)
  cartItems CartItem[]

  orderItems       OrderItem[]
  isReturnable     Boolean     @default(false)
  returnWindowDays Int?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  checkoutSessionItems CheckoutSessionItem[]
  returnRequestItems   ReturnRequestItem[]
  heroSlides HeroSlide[]

  @@index([brandId])
  @@index([categoryId])
}

model ProductImage {
  id       String @id @default(cuid())
  url      String
  position Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id   String  @id @default(cuid())
  name String // "10 tablets", "100ml"
  sku  String? @unique

  price Int
  stock Int

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // added for CartItem relation (opposite side)
  cartItems CartItem[]

  orderItems OrderItem[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  checkoutSessionItems CheckoutSessionItem[]
  returnRequestItems   ReturnRequestItem[]

  @@index([productId])
}

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  checkoutSessionItems CheckoutSessionItem[]

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model StoreSettings {
  id                 String @id @default(cuid())
  deliveryFeeInside  Int    @default(0)
  deliveryFeeOutside Int    @default(0)

  cancelWindowHours       Int @default(24)
  defaultReturnWindowDays Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model HeroSlide {
  id       String @id @default(cuid())
  position Int    @default(0) // sort order

  // Left side
  tag      String // "Baby & Family"
  headline String // "Gentle Care\nfor Every One."  (use \n for line break)
  sub      String // subtitle text
  pill     String // offer pill text e.g. "Dermatologist tested"

  // Buttons
  ctaLabel  String // "Shop Baby Care"
  ctaHref   String // "/products?category=baby-care"
  ctaAltLabel String // "Family wellness"
  ctaAltHref  String // "/products"

  // Right card
  featName  String  // "Baby Wash Gentle"
  featPrice Int     // 599  (in NPR, no commas)
  featOld   Int     // 749
  icon      String  @default("bi-stars") // bootstrap icon class

  // Trust badges (bottom of hero card)
  stat1Val   String @default("100%")
  stat1Label String @default("Genuine")
  stat2Val   String @default("Same Day")
  stat2Label String @default("Delivery")

  // Micro trust line (bottom left)
  micro1 String @default("Verified brands")
  micro2 String @default("Delivers in Kathmandu")
  micro3 String @default("Licensed pharmacy")

  // Styling
  accent String @default("#6BBF4E") // hex color
  bg     String @default("linear-gradient(135deg, #E8F5E2 0%, #F4F8F0 55%, #EEF2F8 100%)")

  // Optionally link to a real product
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  status    String   @default("active") // active | draft
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
  @@index([productId])
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status String @default("Placed") // Placed, Confirmed, Packed, OutForDelivery, Delivered, Cancelled

  subtotal      Int
  discountTotal Int @default(0)
  deliveryFee   Int
  total         Int

  paymentMethod String @default("COD") // only COD in MVP

  fullName    String
  phone       String
  addressLine String
  area        String?
  landmark    String?
  city        String  @default("Kathmandu")

  deliveryZone String // inside | outside

  notes String?

  internalNote String?

  cancelledAt  DateTime?
  cancelReason String?

  deliveredAt DateTime?

  placedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          OrderItem[]
  returnRequests ReturnRequest[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName String
  variantName String?
  unitPrice   Int
  quantity    Int
  lineTotal   Int

  createdAt          DateTime            @default(now())
  returnRequestItems ReturnRequestItem[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model CheckoutSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String @default("active") // active | completed | cancelled | expired

  deliveryZone String? // inside | outside (optional until user selects)
  fullName     String?
  phone        String?
  addressLine  String?
  area         String?
  landmark     String?
  city         String?

  notes String?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CheckoutSessionItem[]

  @@index([userId])
  @@index([status])
}

model CheckoutSessionItem {
  id        String          @id @default(cuid())
  sessionId String
  session   CheckoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  createdAt DateTime @default(now())

  @@unique([sessionId, cartItemId])
  @@index([sessionId])
}

model ReturnRequest {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String  @default("Requested") // Requested | Approved | Rejected | PickedUp | Closed
  reason String
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ReturnRequestItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnRequestItem {
  id String @id @default(cuid())

  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  productName String
  variantName String?
  unitPrice   Int

  createdAt DateTime @default(now())

  @@index([returnRequestId])
  @@index([orderItemId])
}

model PasswordReset {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model StoreInfo {
  id String @id @default("singleton")

  // Basic info
  storeName   String @default("Medisuite")
  tagline     String @default("Pharmacy essentials and skincare you can trust.")
  description String @default("COD delivery with ring-road pricing and clear return rules for eligible products.")

  // Contact
  phone   String @default("+977 9860802178")
  email   String @default("support@medisuite.com")
  address String @default("Kathmandu, Nepal")

  // Hours
  openingHours String @default("9:00 AM – 7:00 PM")
  openDays     String @default("Sunday – Friday")

  // Social
  instagramUrl String @default("")
  facebookUrl  String @default("")
  twitterUrl   String @default("")
  tiktokUrl    String @default("")

  // Footer newsletter
  newsletterEnabled Boolean @default(true)
  newsletterText    String  @default("Get offers + skincare tips")

  // Footer legal links
  termsUrl   String @default("/pages/terms")
  privacyUrl String @default("/pages/privacy")
  refundUrl  String @default("/pages/refund")

  // About page
  aboutHeadline    String @default("About Us")
  aboutSubheadline String @default("We are a modern pharmacy and skincare store.")
  aboutBody        String @default("Focused on quality, safety, and everyday wellness. We deliver genuine products with COD across Kathmandu.")
  aboutMission     String @default("To make quality healthcare accessible for every family.")
  aboutVision      String @default("Nepal's most trusted online pharmacy.")

  // About page stats (shown as highlights)
  stat1Val   String @default("100%")
  stat1Label String @default("Genuine Products")
  stat2Val   String @default("2000+")
  stat2Label String @default("Happy Customers")
  stat3Val   String @default("Same Day")
  stat3Label String @default("Delivery")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
